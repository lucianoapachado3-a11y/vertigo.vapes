{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Publicar cambios",
      "type": "shell",
      "command": "git add -A; git commit -m \"${input:mensaje}\"; git push",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "mensaje",
      "type": "promptString",
      "description": "Mensaje del commit (describí el cambio que hiciste)",
      "default": "Actualizar sitio"
    }
  ]
}
